            "shell_command": "~/.config/karabiner/scripts/dictation-enter.sh route fn-save save 2>/dev/null"
          },
          {
            "set_variable": {
              "name": "dji_dictation_active",
              "value": 1
            }
          }
        ],
        "type": "basic"
      },
