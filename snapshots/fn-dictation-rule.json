{
  "profile": "DJI Mic Dictation",
  "rule": {
    "description": "Fn dictation toggle + confirm/preconfirm to send Enter",
    "manipulators": [
      {
        "conditions": [
          {
            "name": "dji_internal_double_fn",
            "type": "variable_unless",
            "value": 1
          },
          {
            "name": "dji_ready_to_send",
            "type": "variable_if",
            "value": 1
          }
        ],
        "from": {
          "key_code": "fn",
          "modifiers": {
            "optional": [
              "any"
            ]
          }
        },
        "to": [
          {
            "shell_command": "~/.config/karabiner/scripts/dictation-enter.sh route fn-confirm confirm 2>/dev/null"
          }
        ],
        "type": "basic"
      },
      {
        "conditions": [
          {
            "name": "dji_internal_double_fn",
            "type": "variable_unless",
            "value": 1
          },
          {
            "name": "dji_watching",
            "type": "variable_if",
            "value": 1
          }
        ],
        "from": {
          "key_code": "fn",
          "modifiers": {
            "optional": [
              "any"
            ]
          }
        },
        "to": [
          {
            "shell_command": "~/.config/karabiner/scripts/dictation-enter.sh route fn-preconfirm preconfirm 2>/dev/null"
          }
        ],
        "type": "basic"
      },
      {
        "conditions": [
          {
            "name": "dji_internal_double_fn",
            "type": "variable_unless",
            "value": 1
          },
          {
            "name": "dji_dictation_active",
            "type": "variable_if",
            "value": 1
          },
          {
            "name": "dji_watching",
            "type": "variable_unless",
            "value": 1
          },
          {
            "name": "dji_ready_to_send",
            "type": "variable_unless",
            "value": 1
          }
        ],
        "from": {
          "key_code": "fn",
          "modifiers": {
            "optional": [
              "any"
            ]
          }
        },
        "to": [
          {
            "set_variable": {
              "name": "dji_internal_double_fn",
              "value": 1
            }
          },
          {
            "hold_down_milliseconds": 80,
            "key_code": "fn"
          },
          {
            "hold_down_milliseconds": 80,
            "key_code": "vk_none"
          },
          {
            "hold_down_milliseconds": 80,
            "key_code": "fn"
          },
          {
            "set_variable": {
              "name": "dji_internal_double_fn",
              "value": 0
            }
          },
          {
            "set_variable": {
              "name": "dji_dictation_active",
              "value": 0
            }
          },
          {
            "set_variable": {
              "name": "dji_watching",
              "value": 1
            }
          },
          {
            "shell_command": "~/.config/karabiner/scripts/dictation-enter.sh route fn-open-window open-window 2>/dev/null; /usr/bin/nohup ~/.config/karabiner/scripts/dictation-enter.sh route fn-watch watch 2>/dev/null &"
          }
        ],
        "type": "basic"
      },
      {
        "conditions": [
          {
            "name": "dji_internal_double_fn",
            "type": "variable_unless",
